@page "/sessions"

@attribute [Authorize]

@using AgentManager.Models
@using AgentManager.Services
@using MudBlazor
@using System.Collections.ObjectModel

@inject AgentSessionService AgentSessionService
@inject ISnackbar Snackbar

<PageTitle>Sessions</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Sessions</MudText>

    @if (sessions == null)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (!sessions.Any())
    {
        <MudAlert Severity="Severity.Info">No agent sessions yet.</MudAlert>
    }
    else
    {
        <MudDataGrid Items="@sessions" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading">
            <Columns>
                <PropertyColumn Property="x => x.AgentName" Title="Agent" />
                <PropertyColumn Property="x => x.Id" Title="Id" />
                <PropertyColumn Property="x => x.Status" Title="Status" />
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <TemplateColumn Title="Actions" CellClass="d-flex justify-center">
                            <CellTemplate Context="item">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               Disabled="@loading"
                                               OnClick="@(() => RemoveSessionAsync(item.Item))" />
                            </CellTemplate>
                        </TemplateColumn>
                    </Authorized>
                </AuthorizeView>
            </Columns>
        </MudDataGrid>
    }
</MudContainer>

@code {
    private ObservableCollection<AgentSession> sessions = new();
    private bool loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessionsAsync();
        AgentSessionService.OnChange += OnSessionsChange;
    }

    private void OnSessionsChange(AgentSession session)
    {
        _ = InvokeAsync(LoadSessionsAsync);
    }

    private async Task LoadSessionsAsync()
    {
        sessions.Clear();
        loading = true;
        foreach (var s in await AgentSessionService.GetAllAsync())
        {
            sessions.Add(s);
        }
        loading = false;
    }

    private async Task RemoveSessionAsync(AgentSession session)
    {
        try
        {
            await AgentSessionService.RemoveSessionAsync(session.Id);
            Snackbar.Add("Session removed.", Severity.Success);
        }
        catch (InvalidOperationException)
        {
            Snackbar.Add("Cannot remove an active session.", Severity.Error);
        }
        catch (KeyNotFoundException)
        {
            Snackbar.Add("Session not found.", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to remove session.", Severity.Error);
        }
    }

    public void Dispose()
    {
        AgentSessionService.OnChange -= OnSessionsChange;
    }
}
