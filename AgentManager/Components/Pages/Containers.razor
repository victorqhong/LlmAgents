@page "/containers"

@using AgentManager.Models.Containers;
@using AgentManager.Services
@using MudBlazor

@rendermode InteractiveServer

@inject ContainerService ContainerService

@attribute [Authorize]

<PageTitle>Containers</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Containers</MudText>
    <MudButton Variant="Variant.Filled" OnClick="OnClickAllocate">Allocate container</MudButton>
    <MudButton Variant="Variant.Filled" OnClick="OnClickDeallocate">Deallocate container</MudButton>
</MudContainer>

@code {
    async Task OnClickAllocate()
    {
	await ContainerService.AllocateXmppAgent();
    }

    async Task OnClickDeallocate()
    {
	await ContainerService.DeallocateXmppAgent();
    }
}
