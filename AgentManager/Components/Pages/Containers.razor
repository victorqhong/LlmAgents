@page "/containers"

@attribute [Authorize]

@using AgentManager.Models.Containers;
@using AgentManager.Services
@using MudBlazor
@using System.Collections.ObjectModel

@inject ContainerService ContainerService

<PageTitle>Containers</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Containers</MudText>

    <MudDataGrid Items="@allocatedInstances" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading" T="string">
	<Columns>
	    <PropertyColumn Property="x => x" Title="Allocated Agents" />
	    <TemplateColumn Title="Provision" CellClass="d-flex justify-between">
		<CellTemplate Context="item">
		    <MudIconButton
			Icon="@Icons.Material.Filled.Build"
			Color="Color.Primary"
			Size="Size.Small"
			OnClick="@(() => ProvisionInstance(item.Item))" />
		</CellTemplate>
	    </TemplateColumn>
	    <TemplateColumn Title="Deallocate" CellClass="d-flex justify-between">
		<CellTemplate Context="item">
		    <MudIconButton
			Icon="@Icons.Material.Filled.Delete"
			Color="Color.Primary"
			Size="Size.Small"
			OnClick="@(() => DeallocateInstance(item.Item))" />
		</CellTemplate>
	    </TemplateColumn>
	</Columns>
    </MudDataGrid>
    <MudDataGrid Items="@availableInstances" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading" T="string">
	<Columns>
	    <PropertyColumn Property="x => x" Title="Available Agents" />
	    <TemplateColumn Title="Allocate" CellClass="d-flex justify-between">
		<CellTemplate Context="item">
		    <MudIconButton
			Icon="@Icons.Material.Filled.AddToQueue"
			Color="Color.Primary"
			Size="Size.Small"
			OnClick="@(() => AllocateInstance(item.Item))" />
		</CellTemplate>
	    </TemplateColumn>
	</Columns>
    </MudDataGrid>

</MudContainer>

@code {
    private ObservableCollection<string> allocatedInstances = new();
    private ObservableCollection<string> availableInstances = new();
    private bool loading = false;

    protected override void OnInitialized()
    {
        loading = true;
	OnContainerUpdated();
        loading = false;

	ContainerService.OnContainerUpdated += OnContainerUpdated;
    }

    private void OnContainerUpdated()
    {
	allocatedInstances.Clear();
        foreach (var instance in ContainerService.GetAllocatedAgents())
        {
	    allocatedInstances.Add(instance);
        }

	availableInstances.Clear();
        foreach (var instance in ContainerService.GetAvailableAgents())
        {
	    availableInstances.Add(instance);
        }
    }

    public async Task AllocateInstance(string instance)
    {
	await ContainerService.AllocateXmppAgent(instance);
    }

    private async Task DeallocateInstance(string instance)
    {
	await ContainerService.DeallocateXmppAgent(instance);
    }

    public async Task ProvisionInstance(string instance)
    {
	await ContainerService.ProvisionXmppAgent(instance);
    }
}
